{
  "name": "pof-rental-premium-rebuild",
  "version": "1.0.1",
  "private": true,
  "description": "Hybrid Next.js rebuild of the POF Rental website with server-rendered content, an enquiry API, and responsive motion.",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "prebuild": "node scripts/prepare-public.cjs",
    "build": "next build",
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "check:media": "node scripts/check-media.cjs",
    "check": "npm test && npm run check:media && npm run build"
  },
  "dependencies": {
    "next": "^15.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "keywords": [
    "pof-rental",
    "luxury-car-rental",
    "static-site"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1"
  }
}
